# ---- Wails / Go build artefacts ----
build/bin/
build/darwin/
build/linux/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ---- Frontend ----
frontend/node_modules/
frontend/.vite/
*.tsbuildinfo
# Build output is regenerated by `wails build`; keep the dir alive via gitkeep.
frontend/dist/
!frontend/dist/gitkeep

# ---- Local runtime state (these live in %LOCALAPPDATA% / %APPDATA% normally,
# but guard against accidentally placing them in the repo dir during dev). ----
*.db
*.db-shm
*.db-wal
*.log
logs/
cache/
settings.json

# ---- IDE / editor ----
.vscode/
.idea/
*.swp
*.swo
*~

# ---- OS metadata ----
.DS_Store
Thumbs.db
Desktop.ini

# ---- Go workspace files (we don't use them) ----
go.work
go.work.sum

# ---- Misc temp ----
*.tmp
.tmp/
gs-smoke-games.txt
build/smoke-games.txt
frontend/package.json.md5
